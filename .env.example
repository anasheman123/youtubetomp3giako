PORT=3020
NODE_ENV=production
RECENT_LIMIT=60
RECENT_RETENTION_DAYS=30
RECENT_RESPONSE_DEFAULT=12
# Para bloqueos de YouTube en VPS:
# ruta absoluta al archivo cookies.txt exportado (formato Netscape)
# YTDLP_COOKIES_FILE=/opt/gtubeversor/data/youtube-cookies.txt
# opcional: forzar cliente de YouTube (ej: web, android)
# YTDLP_CLIENT=web
# opcional: forzar binario yt-dlp del sistema (recomendado en VPS Linux)
# YTDLP_BINARY=/usr/bin/yt-dlp
# opcional: proxy de salida para yt-dlp (ejemplo Webshare)
# YTDLP_PROXY=http://usuario:password@host:port
# opcional: proxies fallback (solo si falla el principal), separados por coma
# YTDLP_PROXY_FALLBACKS=http://u:p@ip2:port,http://u:p@ip3:port
# opcional
# YTDLP_USER_AGENT=Mozilla/5.0 ...
# Opcional: protege DELETE /api/recent
# ADMIN_TOKEN=pon-un-token-largo
